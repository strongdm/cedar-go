entity User in [Group] {
    name: String,
    email: String,
    age?: Long,
};

entity Group {
    name: String,
};

entity Document in [Folder] {
    title: String,
    public: Bool,
};

entity Folder;

action "view" appliesTo {
    principal: User,
    resource: Document,
    context: {
        ip: ipaddr,
    },
};

action "edit" in [Action::"view"] appliesTo {
    principal: User,
    resource: Document,
};
